#!/bin/bash
# TP=2 vllm-ng17: Qwen3.5-REAP-262B-A17B INT4 AutoRound (RTX self-quantized)
# CUDA Graphs enabled + causal_conv1d/kda patches

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HEAD_CONTAINER="ng17-tp2-head"
WORKER_CONTAINER="ng17-tp2-worker"
MASTER_ADDR="192.168.0.117"
MASTER_PORT=29500
MODEL_PATH="/data/tensordata/Qwen3.5-REAP-262B-A17B-int4-AutoRound-RTX"
MODEL_NAME="qwen3.5-262b"
PORT=8011
MAX_MODEL_LEN=32768

echo "=== vllm-ng17 TP=2: Qwen3.5-REAP-262B INT4 AutoRound (RTX) ==="
echo "Modell: $MODEL_PATH"
echo "CUDA Graphs: enabled (patch_kda_validate)"
echo ""

# Copy serve_torchrun.py + patches to both containers
PATCHES="patch_kda_validate.py patch_qwen35_autoround_weights.py"
podman cp "$SCRIPT_DIR/build/serve_torchrun.py" "$HEAD_CONTAINER:/opt/vllm/serve_torchrun.py"
for p in $PATCHES; do podman cp "$SCRIPT_DIR/$p" "$HEAD_CONTAINER:/opt/vllm/$p"; done
scp -q "$SCRIPT_DIR/build/serve_torchrun.py" $(for p in $PATCHES; do echo "$SCRIPT_DIR/$p"; done) flash@192.168.1.116:/tmp/
ssh flash@192.168.1.116 "podman cp /tmp/serve_torchrun.py $WORKER_CONTAINER:/opt/vllm/serve_torchrun.py; for p in $PATCHES; do podman cp /tmp/\$p $WORKER_CONTAINER:/opt/vllm/\$p; done"
echo "serve_torchrun.py + patches updated in both containers"

# Apply patches in both containers
for p in $PATCHES; do
  podman exec "$HEAD_CONTAINER" python3 /opt/vllm/$p
  ssh flash@192.168.1.116 "podman exec $WORKER_CONTAINER python3 /opt/vllm/$p"
done
echo ""

# Kill any existing torchrun processes
podman exec "$HEAD_CONTAINER" bash -c "pkill -f torchrun 2>/dev/null || true" 2>/dev/null || true
ssh flash@192.168.1.116 "podman exec $WORKER_CONTAINER bash -c 'pkill -f torchrun 2>/dev/null || true'" 2>/dev/null || true
sleep 2

# PGX (Rank 1)
ssh flash@192.168.1.116 "podman exec -d \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  -e VLLM_FLASHINFER_WORKSPACE_BUFFER_SIZE=629145600 \
  $WORKER_CONTAINER bash -c '
  torchrun \
    --nnodes=2 --nproc-per-node=1 --node-rank=1 \
    --master-addr=$MASTER_ADDR --master-port=$MASTER_PORT \
    /opt/vllm/serve_torchrun.py \
      --model $MODEL_PATH \
      --served-model-name $MODEL_NAME \
      --port $PORT \
      --max-model-len $MAX_MODEL_LEN \
      --gpu-memory-utilization 0.05 \
      --kv-cache-memory-bytes 10G \
      --max-num-batched-tokens 8192 \
      --enable-prefix-caching \
      --trust-remote-code \
  > /tmp/worker.log 2>&1
'"

sleep 2

# DGX (Rank 0)
podman exec \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  -e VLLM_FLASHINFER_WORKSPACE_BUFFER_SIZE=629145600 \
  "$HEAD_CONTAINER" \
  torchrun \
    --nnodes=2 --nproc-per-node=1 --node-rank=0 \
    --master-addr="$MASTER_ADDR" --master-port="$MASTER_PORT" \
    /opt/vllm/serve_torchrun.py \
      --model "$MODEL_PATH" \
      --served-model-name "$MODEL_NAME" \
      --port "$PORT" \
      --max-model-len "$MAX_MODEL_LEN" \
      --gpu-memory-utilization 0.05 \
      --kv-cache-memory-bytes 10G \
      --max-num-batched-tokens 8192 \
      --enable-prefix-caching \
      --trust-remote-code \
  2>&1 | tee /tmp/ng17-qwen35-262b-rtx.log
