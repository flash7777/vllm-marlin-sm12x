#!/bin/bash
# TP=2 vllm-ng16: HEAD Container (DGX Spark)
# vLLM 0.16.0rc2 + PyTorch 2.11 + transformers 5.3 + UF17
# Base: nvcr.io/nvidia/vllm:26.02-py3

set -euo pipefail

CONTAINER_NAME="ng16-tp2-head"
IMAGE="localhost/vllm-ng16"
CX7_IF="enp1s0f0np0"

echo "=== vllm-ng16 HEAD Container (DGX Spark) ==="
echo "Container: $CONTAINER_NAME"
echo "Image:     $IMAGE"
echo ""

podman stop "$CONTAINER_NAME" 2>/dev/null || true
podman rm "$CONTAINER_NAME" 2>/dev/null || true

podman run -d \
  --name "$CONTAINER_NAME" \
  --network host \
  --ipc=host \
  --device nvidia.com/gpu=all \
  -v /dev/infiniband:/dev/infiniband \
  --cap-add=IPC_LOCK \
  --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  -v /data/tensordata:/data/tensordata \
  -v "$HOME/.cache/huggingface:/root/.cache/huggingface" \
  -e NCCL_SOCKET_IFNAME="$CX7_IF" \
  -e GLOO_SOCKET_IFNAME="$CX7_IF" \
  -e TP_SOCKET_IFNAME="$CX7_IF" \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IB_HCA=rocep1s0f0 \
  -e NCCL_DEBUG=WARN \
  -e VLLM_MLA_DISABLE=1 \
  -e FLASHINFER_DISABLE_VERSION_CHECK=1 \
  -e VLLM_ENABLE_V1_MULTIPROCESSING=0 \
  -e VLLM_UF_EAGER_ALLREDUCE=1 \
  "$IMAGE" \
  sleep infinity

echo "Container '$CONTAINER_NAME' gestartet (UF17)."
echo "Naechster Schritt: ./start.ng16_tp2.worker"
