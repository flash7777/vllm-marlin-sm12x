ARG BASE_IMAGE=nvcr.io/nvidia/vllm:26.02-py3
FROM ${BASE_IMAGE}

# ============================================================
# vllm-ng17e: ng17 + eugr-Verbesserungen
# Base: nvcr.io/nvidia/vllm:26.02-py3 (PyTorch 2.11, CUDA 13.1.1)
# Targets: SM120a (RTX PRO 6000) + SM121a (DGX Spark GB10)
#
# Von ng17 beibehalten:
#   - UF17 EAGER_ALLREDUCE (+82% TP=2)
#   - Marlin SM12x W4A8/W4A16
#   - MTP/EAGLE3 Patches
#   - Anthropic Streaming Patches
#   - MoE Kernel Configs
#   - serve_torchrun.py (Fallback)
#
# Von eugr uebernommen:
#   - vLLM pinned commit 600a039f5 (dev158, GDN/Mamba Fixes)
#   - FlashInfer 0.6.6 (SM121 custom, prebuilt wheel)
#   - fastsafetensors (schnelleres Model Loading)
#   - Ray cluster support (run-cluster-node.sh)
#   - PR Reverts #34758 + #34302 (Hopper-Code bricht SM121)
#   - fix-qwen3.5-autoround (RoPE set() fix)
#   - UMA-optimierte Ray defaults
#
# Build:
#   cd build && podman build -f Dockerfile.ng17e -t vllm-ng17e .
# ============================================================

# CUDA Dev-Header + libibverbs
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends wget libibverbs-dev && \
    ln -sf libibverbs.so.1 /usr/lib/aarch64-linux-gnu/libibverbs.so && \
    ARCH_DIR=$(dpkg --print-architecture | sed 's/arm64/sbsa/;s/amd64/x86_64/') && \
    wget -qO /tmp/cuda-keyring.deb \
      "https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/${ARCH_DIR}/cuda-keyring_1.1-1_all.deb" && \
    dpkg -i /tmp/cuda-keyring.deb && rm /tmp/cuda-keyring.deb && \
    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      libcusparse-dev-13-1 \
      libcusolver-dev-13-1 \
      libcufft-dev-13-1 && \
    rm -rf /var/lib/apt/lists/*

# Build-Dependencies
RUN pip install --no-cache-dir cmake ninja setuptools-scm

# ============================================================
# CUTLASS 4.4.0 (SM120a/SM121a Support + DSL)
# ============================================================
RUN git clone --depth 1 --branch v4.4.0 \
      https://github.com/NVIDIA/cutlass.git /opt/cutlass
ENV VLLM_CUTLASS_SRC_DIR=/opt/cutlass

RUN sed -i '/nvidia-cutlass-dsl/d' /etc/pip/constraint.txt && \
    echo "4.4.0" > /opt/cutlass/python/CuTeDSL/VERSION.EDITABLE && \
    pip install --no-cache-dir --force-reinstall --no-deps /opt/cutlass/python/CuTeDSL

# ============================================================
# vLLM from source — pinned commit 600a039f5 (dev158, 2026-03-14)
# Fixes GDN/Mamba CUDA assert + Qwen3.5 hybrid stability
# ============================================================
RUN git clone --filter=blob:none \
      https://github.com/vllm-project/vllm.git /tmp/vllm-build && \
    cd /tmp/vllm-build && \
    git checkout 600a039f5

WORKDIR /tmp/vllm-build

# ============================================================
# eugr PR Reverts (Hopper-Code bricht SM121 Build)
# ============================================================
RUN curl -fL https://github.com/vllm-project/vllm/pull/34758.diff | patch -p1 -R || echo "PR #34758: already reverted or n/a"
RUN curl -fL https://github.com/vllm-project/vllm/pull/34302.diff | patch -p1 -R || echo "PR #34302: already reverted or n/a"

# ============================================================
# Marlin SM121 Patch (SM12x family support for W4A8-FP8)
# ============================================================
COPY marlin_sm12x.patch /tmp/
RUN git apply /tmp/marlin_sm12x.patch || echo "Marlin SM12x patch: already applied or code changed"

# Existierendes PyTorch nutzen (NVIDIA's 2.11+cu131)
RUN python use_existing_torch.py

# Remove flashinfer pin — wir installieren eugr's 0.6.6 separat
RUN sed -i '/flashinfer-python/d' requirements/cuda.txt 2>/dev/null || true && \
    sed -i '/flashinfer-python/d' pyproject.toml 2>/dev/null || true

# Build-Requirements
RUN pip install --no-cache-dir -r requirements/build.txt

# Altes vLLM entfernen
RUN pip uninstall -y vllm

# vLLM bauen mit CUTLASS fuer SM120a + SM121a
ENV TORCH_CUDA_ARCH_LIST="12.0a;12.1a"
ENV VLLM_TARGET_DEVICE=cuda
ENV MAX_JOBS=16
RUN pip install --no-build-isolation --no-cache-dir .

# Aufraeumen
WORKDIR /
RUN rm -rf /tmp/vllm-build

# ============================================================
# FlashInfer 0.6.6 (eugr's SM121 custom build)
# Prebuilt wheel von /data/tensordata/wheels/eugr-20260314/
# ============================================================
COPY wheels/flashinfer*.whl /tmp/wheels/
RUN pip install --no-cache-dir --force-reinstall /tmp/wheels/flashinfer*.whl && \
    rm -rf /tmp/wheels

# ============================================================
# fastsafetensors + Ray (eugr)
# ============================================================
RUN pip install --no-cache-dir fastsafetensors ray[default] nvidia-nvshmem-cu13

# ============================================================
# transformers 5.x + dependencies
# ============================================================
RUN pip install --no-cache-dir --no-deps "transformers>=5.2" && \
    pip install --no-cache-dir --upgrade "huggingface_hub>=0.32" && \
    pip install --no-cache-dir --no-deps "compressed-tensors>=0.13"

# ============================================================
# eugr fix-qwen3.5-autoround (RoPE set() fix for transformers 5.x)
# ============================================================
COPY eugr-mods/fix-qwen3.5-autoround/transformers.patch /tmp/
RUN cd /usr/local/lib/python3.12/dist-packages && \
    patch -p1 < /tmp/transformers.patch || echo "RoPE patch: already applied or n/a"

# ============================================================
# Patches (ng17 — robust, alle exit 0 bei "pattern not found")
# ============================================================

# Patches 3,4,7,8,11 (compressed_tensors, MoE fallback, buffers, streaming)
COPY patch_transformers.py /tmp/
RUN python3 /tmp/patch_transformers.py || echo "WARN: patch_transformers.py (may be upstream)"

# Patch streaming (Anthropic adapter tool_calls Fixes)
COPY patch_streaming.py /tmp/
RUN python3 /tmp/patch_streaming.py || echo "WARN: patch_streaming.py (may be upstream)"

# MTP NVFP4 Exclusion
COPY patch_mtp_nvfp4_exclusion.py /tmp/
RUN python3 /tmp/patch_mtp_nvfp4_exclusion.py || echo "WARN: patch_mtp_nvfp4_exclusion.py (may be upstream)"

# MTP BF16 Weights
COPY patch_mtp_bf16_weights.py /tmp/
RUN python3 /tmp/patch_mtp_bf16_weights.py || echo "WARN: patch_mtp_bf16_weights.py (may be upstream)"

# Marlin N-Padding
COPY patch_marlin_padding.py /tmp/
RUN python3 /tmp/patch_marlin_padding.py || echo "WARN: patch_marlin_padding.py (may be upstream)"

# Qwen3-Next/Qwen3.5 torch.compile Fix
COPY patch_qwen3next_compile.py /tmp/
RUN python3 /tmp/patch_qwen3next_compile.py || echo "WARN: (may be upstream)"
COPY patch_qwen3next_compile_v2.py /tmp/
RUN python3 /tmp/patch_qwen3next_compile_v2.py || echo "WARN: (may be upstream)"
COPY patch_qwen35_compile.py /tmp/
RUN python3 /tmp/patch_qwen35_compile.py || echo "WARN: (may be upstream)"

# Qwen3-Next EAGLE3 interface
COPY patch_qwen3next_eagle3.py /tmp/
RUN python3 /tmp/patch_qwen3next_eagle3.py || echo "WARN: (may be upstream)"

# UF17v3: EAGER_ALLREDUCE — NCCL AllReduce outside CUDA Graphs (+82% TP=2)
COPY patch_uf17_eager_allreduce.py /tmp/
RUN python3 /tmp/patch_uf17_eager_allreduce.py || echo "WARN: UF17 patch failed — check patterns for dev158"

# torch._opaque_base Fix
COPY patch_torch_opaque.py /tmp/
RUN python3 /tmp/patch_torch_opaque.py || echo "WARN: torch opaque (may be upstream)"

# cv2/typing shadowing fix
RUN rm -rf /usr/local/lib/python3.12/dist-packages/cv2/typing 2>/dev/null || true

# ============================================================
# Multi-node serving
# ============================================================
RUN mkdir -p /opt/vllm
COPY serve_torchrun.py /opt/vllm/serve_torchrun.py
COPY eugr-mods/run-cluster-node.sh /opt/vllm/run-cluster-node.sh
RUN chmod +x /opt/vllm/run-cluster-node.sh

# ============================================================
# MoE Kernel Configs (getunt fuer GB10 + RTX PRO 6000)
# ============================================================
COPY moe-configs/*.json /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/configs/

# ============================================================
# Runtime env defaults (UMA-optimiert, eugr)
# ============================================================
ENV FLASHINFER_CUDA_ARCH_LIST="12.0a 12.1a"
ENV RAY_memory_monitor_refresh_ms=0
ENV RAY_object_store_memory=1073741824
ENV RAY_num_prestart_python_workers=0

# ============================================================
# Verify
# ============================================================
RUN python3 -c "\
import vllm; print('vLLM:', vllm.__version__); \
import transformers; print('transformers:', transformers.__version__); \
import flashinfer; print('FlashInfer:', flashinfer.__version__); \
import torch; print('PyTorch:', torch.__version__); \
print('CUDA:', torch.version.cuda); \
import fastsafetensors; print('fastsafetensors: OK'); \
import ray; print('Ray:', ray.__version__); \
import os; \
assert os.path.exists('/opt/vllm/serve_torchrun.py'); \
print('torchrun: serve_torchrun.py installed'); \
assert os.path.exists('/opt/vllm/run-cluster-node.sh'); \
print('ray: run-cluster-node.sh installed')"

# Verify UF17 patch (file-based, no import)
RUN grep -q 'VLLM_UF_EAGER_ALLREDUCE' /usr/local/lib/python3.12/dist-packages/vllm/config/compilation.py && \
    echo "UF17: EAGER_ALLREDUCE verified" || echo "UF17: WARNING — needs update"
