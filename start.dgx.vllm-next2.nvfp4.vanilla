#!/bin/bash
# DGX Spark | vLLM-next2 | Qwen3-Coder NVFP4 | Vanilla
# Image: localhost/vllm-next2
# Regression-Check: Baseline 65.0 tok/s (vllm-next)
# FIX SM121: Dual-Arch CUTLASS JIT
podman run -d \
  --replace \
  --name vllm-next2-nvfp4 \
  --device nvidia.com/gpu=all \
  --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  --network host \
  -v /data/tensordata:/data/tensordata \
  -e FLASHINFER_DISABLE_VERSION_CHECK=1 \
  -e FLASHINFER_CUDA_ARCH_LIST="12.0a 12.1a" \
  localhost/vllm-next2 \
  vllm serve /data/tensordata/Qwen3-Coder-30B-A3B-Instruct-FP4 \
    --host 0.0.0.0 \
    --port 8011 \
    --served-model-name qwen3-coder-nvfp4 \
    --gpu-memory-utilization 0.33 \
    --kv-cache-memory-bytes 10G \
    --kv-cache-dtype fp8 \
    --max-model-len 32768 \
    --trust-remote-code
