#!/bin/bash
# TP=1 vllm-ng17: Qwen3.5-122B-A10B INT4 AutoRound (Single GPU) — 256K Context
# RTX PRO 6000 (97GB VRAM)
# Community fixes: VLLM_MARLIN_USE_ATOMIC_ADD
# Ref: https://forums.developer.nvidia.com/t/361967

set -euo pipefail

CONTAINER_NAME="vllm-ng17-qwen35-122b"
IMAGE="localhost/vllm-ng17"
MODEL_PATH="/data/tensordata/Qwen3.5-122B-A10B-int4-AutoRound"
MODEL_NAME="qwen3.5-122b"
PORT=8011
MAX_MODEL_LEN=262144

echo "=== vllm-ng17 TP=1: Qwen3.5-122B INT4 AutoRound ==="
echo "Container: $CONTAINER_NAME"
echo "Image:     $IMAGE"
echo "Modell:    $MODEL_PATH"
echo "Port:      $PORT"
echo ""

# Stop existing container
podman stop "$CONTAINER_NAME" 2>/dev/null || true
podman rm "$CONTAINER_NAME" 2>/dev/null || true

podman run -d \
  --name "$CONTAINER_NAME" \
  --device nvidia.com/gpu=all \
  --ipc=host \
  --security-opt=label=disable \
  -v /data/tensordata:/data/tensordata:ro \
  -v "$HOME/.cache/huggingface:/root/.cache/huggingface" \
  -p "${PORT}:${PORT}" \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e FLASHINFER_DISABLE_VERSION_CHECK=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  "$IMAGE" \
  python3 -m vllm.entrypoints.openai.api_server \
    --model "$MODEL_PATH" \
    --served-model-name "$MODEL_NAME" \
    --host 0.0.0.0 \
    --port "$PORT" \
    --max-model-len "$MAX_MODEL_LEN" \
    --gpu-memory-utilization 0.90 \
    --kv-cache-dtype fp8 \
    --enable-prefix-caching \
    --enforce-eager \
    --trust-remote-code \
    --enable-auto-tool-choice \
    --tool-call-parser qwen3_coder \
    --reasoning-parser qwen3

echo ""
echo "Container '$CONTAINER_NAME' gestartet."
echo "Logs: podman logs -f $CONTAINER_NAME"
echo "API:  http://localhost:${PORT}/v1/chat/completions"
echo ""

# Follow logs
podman logs -f "$CONTAINER_NAME"
