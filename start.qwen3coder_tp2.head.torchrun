#!/bin/bash
# TP=2 Qwen3-Coder-30B INT4 AutoRound: HEAD Container (DGX Spark)
# torchrun-based (kein Ray)
#
# Reihenfolge:
#   1. DGX:  ./start.qwen3coder_tp2.head.torchrun
#   2. PGX:  ./start.qwen3coder_tp2.worker.torchrun
#   3. DGX:  ./start.qwen3coder_tp2.serve.torchrun

set -euo pipefail

CONTAINER_NAME="qwen3coder-tp2-head"
IMAGE="localhost/vllm-unified"
HEAD_IP="192.168.0.117"
CX7_IF="enp1s0f0np0"

echo "=== torchrun HEAD Container starten (DGX Spark) ==="
echo "Container: $CONTAINER_NAME"
echo "Image:     $IMAGE"
echo ""

podman stop "$CONTAINER_NAME" 2>/dev/null || true
podman rm "$CONTAINER_NAME" 2>/dev/null || true

podman run -d \
  --name "$CONTAINER_NAME" \
  --network host \
  --ipc=host \
  --device nvidia.com/gpu=all \
  --device /dev/infiniband/uverbs0 \
  --device /dev/infiniband/rdma_cm \
  --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  -v /data/tensordata:/data/tensordata \
  -v "$HOME/.cache/huggingface:/root/.cache/huggingface" \
  -e NCCL_SOCKET_IFNAME="$CX7_IF" \
  -e GLOO_SOCKET_IFNAME="$CX7_IF" \
  -e TP_SOCKET_IFNAME="$CX7_IF" \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IB_HCA=rocep1s0f0 \
  -e NCCL_DEBUG=WARN \
  -e VLLM_MLA_DISABLE=1 \
  -e FLASHINFER_DISABLE_VERSION_CHECK=1 \
  -e VLLM_ENABLE_V1_MULTIPROCESSING=0 \
  "$IMAGE" \
  sleep infinity

echo "Container '$CONTAINER_NAME' gestartet."
echo "Naechster Schritt: ./start.qwen3coder_tp2.worker.torchrun"
