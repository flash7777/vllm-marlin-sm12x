#!/bin/bash
# TP=2 vllm-ng: GLM-4.7-Flash INT4 AutoRound (vanilla, kein EAGLE3)
# EAGLE3 nicht supported fuer glm4_moe_lite model_type in vLLM 0.15.
# Voraussetzung: ng-tp2-head + ng-tp2-worker Container laufen

set -euo pipefail

HEAD_CONTAINER="ng-tp2-head"
WORKER_CONTAINER="ng-tp2-worker"
MASTER_ADDR="192.168.0.117"
MASTER_PORT=29500
MODEL_PATH="/data/tensordata/GLM-4.7-Flash-int4-AutoRound"
MODEL_NAME="glm-4.7-flash"
PORT=8011
MAX_MODEL_LEN=16384

echo "=== vllm-ng TP=2 + UF17: GLM-4.7-Flash INT4 (vanilla) ==="
echo "Modell:  $MODEL_PATH"
echo ""

# PGX (Rank 1)
ssh flash@192.168.1.116 "podman exec -d $WORKER_CONTAINER \
  torchrun \
    --nnodes=2 --nproc-per-node=1 --node-rank=1 \
    --master-addr=$MASTER_ADDR --master-port=$MASTER_PORT \
    /opt/vllm/serve_torchrun.py \
      --model $MODEL_PATH \
      --served-model-name $MODEL_NAME \
      --port $PORT \
      --max-model-len $MAX_MODEL_LEN \
      --gpu-memory-utilization 0.05 \
      --kv-cache-memory-bytes 10G \
      --quantization auto_round \
      --trust-remote-code"

sleep 2

# DGX (Rank 0)
podman exec "$HEAD_CONTAINER" \
  torchrun \
    --nnodes=2 --nproc-per-node=1 --node-rank=0 \
    --master-addr="$MASTER_ADDR" --master-port="$MASTER_PORT" \
    /opt/vllm/serve_torchrun.py \
      --model "$MODEL_PATH" \
      --served-model-name "$MODEL_NAME" \
      --port "$PORT" \
      --max-model-len "$MAX_MODEL_LEN" \
      --gpu-memory-utilization 0.05 \
      --kv-cache-memory-bytes 10G \
      --quantization auto_round \
      --trust-remote-code \
  2>&1 | tee /tmp/ng-glm47-vanilla.log
