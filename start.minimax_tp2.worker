#!/bin/bash
# TP=2 MiniMax-M2.5 INT4 AutoRound: Ray WORKER Node (PGX ThinkStation)
# Image: vllm-next2
#
# Reihenfolge:
#   1. DGX:  ./start.minimax_tp2.head
#   2. PGX:  ./start.minimax_tp2.worker  <-- DU BIST HIER
#   3. DGX:  ./start.minimax_tp2.serve (oder .serve.mtp)

set -euo pipefail

CONTAINER_NAME="minimax-worker"
IMAGE="localhost/vllm-next2"
HEAD_IP="192.168.0.117"
WORKER_IP="192.168.0.116"
CX7_IF="enp1s0f0np0"

echo "=== Ray WORKER Node starten (PGX ThinkStation) ==="
echo "Worker-IP: $WORKER_IP"
echo "Head-IP:   $HEAD_IP:6379"
echo "Interface: $CX7_IF"
echo "Image:     $IMAGE"
echo ""

# Alten Container aufräumen
podman stop "$CONTAINER_NAME" 2>/dev/null || true
podman rm "$CONTAINER_NAME" 2>/dev/null || true
podman system migrate 2>/dev/null || true

# WORKAROUND: nohup + foreground-Modus nötig wegen Podman 4.9.3/Kernel 6.17
# Container verliert sonst Prozess-Tracking nach ~10s (Created-Bug)
#
# KEIN CDI! System-CDI (/etc/cdi/nvidia.yaml) hat card1-Bug (PGX hat nur card0).
# Stattdessen: manuelle Device-Mounts + libnvidia-ml.so Volume-Mount.
# libcuda.so kommt aus dem Container-Image (CUDA compat layer).
NVML_LIB="/usr/lib/aarch64-linux-gnu/libnvidia-ml.so.590.48.01"
NVML_DEST="/usr/lib/aarch64-linux-gnu"

nohup podman run \
  --name "$CONTAINER_NAME" \
  --network host \
  --ipc=host \
  --device /dev/nvidia0 \
  --device /dev/nvidiactl \
  --device /dev/nvidia-uvm \
  --device /dev/nvidia-uvm-tools \
  --device /dev/dri/card0 \
  --device /dev/dri/renderD128 \
  --device /dev/infiniband/uverbs0 \
  --device /dev/infiniband/rdma_cm \
  --security-opt=label=disable \
  -v /data/tensordata:/data/tensordata \
  -v "$HOME/.cache/huggingface:/root/.cache/huggingface" \
  -v "$NVML_LIB:$NVML_DEST/libnvidia-ml.so.590.48.01:ro" \
  -v "$NVML_LIB:$NVML_DEST/libnvidia-ml.so.1:ro" \
  -v "$NVML_LIB:$NVML_DEST/libnvidia-ml.so:ro" \
  -e VLLM_HOST_IP="$WORKER_IP" \
  -e NCCL_SOCKET_IFNAME="$CX7_IF" \
  -e GLOO_SOCKET_IFNAME="$CX7_IF" \
  -e TP_SOCKET_IFNAME="$CX7_IF" \
  -e UCX_NET_DEVICES="$CX7_IF" \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IB_HCA=rocep1s0f0 \
  -e NCCL_DEBUG=INFO \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e VLLM_MLA_DISABLE=1 \
  -e FLASHINFER_DISABLE_VERSION_CHECK=1 \
  "$IMAGE" \
  ray start --block --num-gpus=1 --num-cpus=20 \
    --address="$HEAD_IP:6379" --node-ip-address="$WORKER_IP" \
  > /tmp/minimax-worker.log 2>&1 &

sleep 5

if podman ps | grep -q "$CONTAINER_NAME"; then
  echo ""
  echo "Container '$CONTAINER_NAME' läuft."
  echo "Worker verbindet sich mit Head $HEAD_IP:6379"
  echo ""
  echo "Nächster Schritt: Auf DGX vLLM serve starten"
  echo "  ./start.minimax_tp2.serve"
  echo ""
  echo "Logs: tail -f /tmp/minimax-worker.log"
else
  echo "FEHLER: Container nicht gestartet!"
  tail -10 /tmp/minimax-worker.log
  exit 1
fi
