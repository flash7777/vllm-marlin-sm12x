#!/bin/bash
# TP=2 Ray: Qwen3.5-397B-A17B INT4 AutoRound (Full MoE, 512 Experts)
# Based on eugr/spark-vllm-docker approach: Ray cluster + vllm serve
# No serve_torchrun.py — uses native vLLM distributed serving

set -euo pipefail

HEAD_CONTAINER="ng17-tp2-head"
WORKER_CONTAINER="ng17-tp2-worker"
HEAD_IP="192.168.0.117"
WORKER_IP="192.168.0.116"
ETH_IF="enp1s0f0np0"
MODEL_PATH="/data/tensordata/Qwen3.5-397B-A17B-int4-AutoRound"
MODEL_NAME="qwen3.5-397b"
PORT=8011

echo "=== Ray TP=2: Qwen3.5-397B-A17B INT4 AutoRound ==="
echo "Head: $HEAD_IP (DGX), Worker: $WORKER_IP (PGX)"
echo ""

# Recreate containers with env vars baked in (survives ray subprocess fork)
echo "Recreating containers with UMA env vars..."
podman stop "$HEAD_CONTAINER" 2>/dev/null; podman rm "$HEAD_CONTAINER" 2>/dev/null
podman run -d --name "$HEAD_CONTAINER" \
  --device nvidia.com/gpu=all --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  --network host --ipc host \
  -v /data/tensordata:/data/tensordata \
  -v /dev/infiniband:/dev/infiniband \
  -v /home/flash/.cache/huggingface:/root/.cache/huggingface \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  -e VLLM_HOST_IP=$HEAD_IP \
  -e RAY_NODE_IP_ADDRESS=$HEAD_IP \
  localhost/vllm-ng-latest:latest sleep infinity

ssh flash@192.168.1.116 "podman stop $WORKER_CONTAINER 2>/dev/null; podman rm $WORKER_CONTAINER 2>/dev/null; \
podman run -d --name $WORKER_CONTAINER \
  --device nvidia.com/gpu=all --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  --network host --ipc host \
  -v /data/tensordata:/data/tensordata \
  -v /dev/infiniband:/dev/infiniband \
  -v /home/flash/.cache/huggingface:/root/.cache/huggingface \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  -e VLLM_HOST_IP=$WORKER_IP \
  -e RAY_NODE_IP_ADDRESS=$WORKER_IP \
  localhost/vllm-ng-latest:latest sleep infinity"
sleep 3

# Kill existing Ray/vllm processes
podman exec "$HEAD_CONTAINER" bash -c "ray stop 2>/dev/null; pkill -f 'vllm serve' 2>/dev/null || true" 2>/dev/null || true
ssh flash@192.168.1.116 "podman exec $WORKER_CONTAINER bash -c 'ray stop 2>/dev/null; pkill -f vllm 2>/dev/null || true'" 2>/dev/null || true
sleep 2

# Common env vars for both nodes
ENV_VARS="-e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e VLLM_HOST_IP=\$NODE_IP \
  -e RAY_NODE_IP_ADDRESS=\$NODE_IP \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1"

# Start Ray Worker on PGX (must be running before head starts vllm serve)
echo "Starting Ray worker on PGX..."
ssh flash@192.168.1.116 "podman exec -d \
  -e NODE_IP=$WORKER_IP \
  -e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e VLLM_HOST_IP=$WORKER_IP \
  -e RAY_NODE_IP_ADDRESS=$WORKER_IP \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  $WORKER_CONTAINER bash -c '
  ray start --block --object-store-memory 1073741824 --num-cpus 2 \
    --disable-usage-stats --address=\"$HEAD_IP:6379\" \
    --node-ip-address $WORKER_IP \
  > /tmp/ray-worker.log 2>&1
'"
echo "Ray worker started (detached)"

# Start Ray Head on DGX
echo "Starting Ray head on DGX..."
podman exec -d \
  -e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e VLLM_HOST_IP=$HEAD_IP \
  -e RAY_NODE_IP_ADDRESS=$HEAD_IP \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  "$HEAD_CONTAINER" bash -c "
  ray start --head --port 6379 --object-store-memory 1073741824 --num-cpus 2 \
    --node-ip-address $HEAD_IP --include-dashboard=false --disable-usage-stats
"
sleep 5

# Wait for worker to connect
echo "Waiting for Ray cluster (2 nodes)..."
for i in $(seq 1 30); do
  NODES=$(podman exec "$HEAD_CONTAINER" bash -c "ray status 2>/dev/null | grep -c 'node_' || echo 0")
  if [ "$NODES" -ge 2 ]; then
    echo "Ray cluster ready: $NODES nodes"
    break
  fi
  sleep 2
done

# Launch vllm serve
echo "Starting vllm serve..."
podman exec \
  -e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e VLLM_HOST_IP=$HEAD_IP \
  -e RAY_NODE_IP_ADDRESS=$HEAD_IP \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e RAY_memory_monitor_refresh_ms=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1 \
  "$HEAD_CONTAINER" \
  vllm serve "$MODEL_PATH" \
    --served-model-name "$MODEL_NAME" \
    --host 0.0.0.0 \
    --port "$PORT" \
    --max-model-len 131072 \
    --gpu-memory-utilization 0.05 \
    --kv-cache-memory-bytes 5G \
    --kv-cache-dtype fp8 \
    --max-num-seqs 16 \
    --max-num-batched-tokens 8192 \
    --enable-prefix-caching \
    --trust-remote-code \
    --tensor-parallel-size 2 \
    --distributed-executor-backend ray \
  2>&1 | tee /tmp/ray-qwen35-397b.log
