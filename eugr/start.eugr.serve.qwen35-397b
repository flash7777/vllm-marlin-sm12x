#!/bin/bash
# Qwen3.5-397B-A17B INT4 AutoRound — eugr/spark-vllm-docker approach
# Ray cluster + vllm serve, prebuilt wheels, fastsafetensors

set -euo pipefail

HEAD_CONTAINER="eugr-head"
WORKER_CONTAINER="eugr-worker"
HEAD_IP="192.168.0.117"
WORKER_IP="192.168.0.116"
ETH_IF="enp1s0f0np0"
IMAGE="localhost/vllm-eugr:latest"

MODEL="Intel/Qwen3.5-397B-A17B-int4-AutoRound"
MODEL_PATH="/data/tensordata/Qwen3.5-397B-A17B-int4-AutoRound"
MODEL_NAME="qwen3.5-397b"
PORT=8011

echo "=== eugr-style: Qwen3.5-397B TP=2 ==="
echo "Image: $IMAGE"
echo "Head: $HEAD_IP, Worker: $WORKER_IP"
echo ""

# UMA env vars (baked into container)
UMA_ENVS="\
  -e RAY_memory_monitor_refresh_ms=0 \
  -e RAY_object_store_memory=1073741824 \
  -e RAY_num_prestart_python_workers=0 \
  -e VLLM_MARLIN_USE_ATOMIC_ADD=1 \
  -e NCCL_SOCKET_IFNAME=$ETH_IF \
  -e GLOO_SOCKET_IFNAME=$ETH_IF \
  -e NCCL_IB_DISABLE=0 \
  -e NCCL_IGNORE_CPU_AFFINITY=1 \
  -e TORCH_CUDNN_V8_API_DISABLED=1"

# Recreate containers
echo "Creating containers..."
podman stop "$HEAD_CONTAINER" 2>/dev/null; podman rm "$HEAD_CONTAINER" 2>/dev/null
podman run -d --name "$HEAD_CONTAINER" \
  --device nvidia.com/gpu=all --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  --network host --ipc host \
  -v /data/tensordata:/data/tensordata \
  -v /dev/infiniband:/dev/infiniband \
  -v /home/flash/.cache/huggingface:/root/.cache/huggingface \
  $UMA_ENVS \
  -e VLLM_HOST_IP=$HEAD_IP \
  -e RAY_NODE_IP_ADDRESS=$HEAD_IP \
  "$IMAGE" sleep infinity

ssh flash@192.168.1.116 "podman stop $WORKER_CONTAINER 2>/dev/null; podman rm $WORKER_CONTAINER 2>/dev/null; \
podman run -d --name $WORKER_CONTAINER \
  --device nvidia.com/gpu=all --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  --network host --ipc host \
  -v /data/tensordata:/data/tensordata \
  -v /dev/infiniband:/dev/infiniband \
  -v /home/flash/.cache/huggingface:/root/.cache/huggingface \
  $UMA_ENVS \
  -e VLLM_HOST_IP=$WORKER_IP \
  -e RAY_NODE_IP_ADDRESS=$WORKER_IP \
  $IMAGE sleep infinity"
sleep 3

# Apply mods (fix-qwen3.5-autoround)
echo "Applying mods..."
MODS_DIR="$(dirname "$0")/../spark-vllm-docker/mods"
for mod in fix-qwen3.5-autoround fix-qwen3.5-chat-template; do
  if [ -d "$MODS_DIR/$mod" ]; then
    echo "  Applying $mod..."
    podman cp "$MODS_DIR/$mod" "$HEAD_CONTAINER:/workspace/mods/$mod"
    podman exec -w /workspace/mods/$mod "$HEAD_CONTAINER" bash run.sh 2>&1 || echo "  $mod: already applied or n/a"
    # Worker too
    cat "$MODS_DIR/$mod/run.sh" | ssh flash@192.168.1.116 "podman exec -i $WORKER_CONTAINER bash -c 'mkdir -p /workspace/mods/$mod && cat > /workspace/mods/$mod/run.sh'"
    for f in "$MODS_DIR/$mod"/*.patch; do
      [ -f "$f" ] && cat "$f" | ssh flash@192.168.1.116 "podman exec -i $WORKER_CONTAINER bash -c 'cat > /workspace/mods/$mod/$(basename $f)'"
    done
    ssh flash@192.168.1.116 "podman exec -w /workspace/mods/$mod $WORKER_CONTAINER bash run.sh" 2>&1 || echo "  $mod (PGX): already applied or n/a"
  fi
done
echo ""

# Start Ray Worker on PGX
echo "Starting Ray worker on PGX..."
ssh flash@192.168.1.116 "podman exec -d $WORKER_CONTAINER bash -c '
  ray start --block --object-store-memory 1073741824 --num-cpus 2 \
    --disable-usage-stats --address=\"$HEAD_IP:6379\" \
    --node-ip-address $WORKER_IP \
  > /tmp/ray-worker.log 2>&1
'"

# Start Ray Head on DGX
echo "Starting Ray head on DGX..."
podman exec -d "$HEAD_CONTAINER" bash -c "
  ray start --head --port 6379 --object-store-memory 1073741824 --num-cpus 2 \
    --node-ip-address $HEAD_IP --include-dashboard=false --disable-usage-stats
"
sleep 5

# Wait for Ray cluster
echo "Waiting for Ray cluster..."
for i in $(seq 1 30); do
  NODES=$(podman exec "$HEAD_CONTAINER" bash -c "ray status 2>/dev/null | grep -c 'node_' || echo 0")
  if [ "$NODES" -ge 2 ]; then
    echo "Ray cluster: $NODES nodes ready"
    break
  fi
  sleep 2
done

# Launch vllm serve (eugr recipe style)
echo "Starting vllm serve..."
podman exec "$HEAD_CONTAINER" \
  vllm serve "$MODEL_PATH" \
    --served-model-name "$MODEL_NAME" \
    --host 0.0.0.0 \
    --port "$PORT" \
    --max-model-len 262144 \
    --gpu-memory-utilization 0.05 \
    --kv-cache-memory-bytes 8G \
    --kv-cache-dtype fp8 \
    --max-num-seqs 3 \
    --max-num-batched-tokens 8192 \
    --load-format fastsafetensors \
    --enable-prefix-caching \
    --enable-auto-tool-choice \
    --tool-call-parser qwen3_coder \
    --reasoning-parser qwen3 \
    --trust-remote-code \
    --tensor-parallel-size 2 \
    --distributed-executor-backend ray \
  2>&1 | tee /tmp/eugr-qwen35-397b.log
