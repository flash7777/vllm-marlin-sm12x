#!/bin/bash
# DGX Spark | vLLM-next2 | Qwen3-Coder INT4 W4A16 | EAGLE3 NST=1
# Image: localhost/vllm-next2
# Regression-Check: Baseline 97.4 tok/s (vllm-next)
podman run -d \
  --replace \
  --name vllm-next2-int4-eagle3 \
  --device nvidia.com/gpu=all \
  --security-opt=label=disable \
  --hooks-dir=/usr/share/containers/oci/hooks.d \
  --network host \
  -v /data/tensordata:/data/tensordata \
  -e FLASHINFER_DISABLE_VERSION_CHECK=1 \
  -e FLASHINFER_CUDA_ARCH_LIST="12.0a 12.1a" \
  localhost/vllm-next2 \
  vllm serve /data/tensordata/Qwen3-Coder-30B-A3B-Instruct-int4-AutoRound \
    --host 0.0.0.0 \
    --port 8011 \
    --served-model-name qwen3-coder-int4-eagle3 \
    --gpu-memory-utilization 0.33 \
    --kv-cache-memory-bytes 10G \
    --kv-cache-dtype fp8 \
    --max-model-len 32768 \
    --trust-remote-code \
    --speculative-config '{"model": "/data/tensordata/SGLang-EAGLE3-Qwen3-Coder-30B-A3B", "num_speculative_tokens": 1, "method": "eagle3"}'
