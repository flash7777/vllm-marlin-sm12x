#!/bin/bash
# TP=2 MiniMax-M2.5 INT4 AutoRound: vLLM Serve — MTP NST=1
# MiniMax hat 3 MTP-Module (use_mtp=true, num_mtp_modules=3)

set -euo pipefail

CONTAINER_NAME="minimax-head"
MODEL_PATH="/data/tensordata/MiniMax-M2.5-int4-AutoRound/MiniMax-M2.5-w4g128"
PORT=8011
LOGFILE="/tmp/minimax-tp2-serve-mtp.log"

echo "=== Ray Cluster Status pruefen ==="
podman exec "$CONTAINER_NAME" ray status
echo ""

echo "=== vLLM serve starten (TP=2, MTP NST=1) ==="
echo "Modell:  $MODEL_PATH"
echo "Port:    $PORT"
echo "Spec:    MTP NST=1"
echo ""

nohup podman exec "$CONTAINER_NAME" \
  vllm serve "$MODEL_PATH" \
    --host 0.0.0.0 \
    --port "$PORT" \
    --served-model-name minimax-m2.5 \
    --tensor-parallel-size 2 \
    --distributed-executor-backend ray \
    --gpu-memory-utilization 0.05 \
    --kv-cache-memory-bytes 25G \
    --max-model-len 65536 \
    --trust-remote-code \
    --quantization auto_round \
    --speculative-config '{"method": "mtp", "num_speculative_tokens": 1}' \
    --disable-log-requests \
  > "$LOGFILE" 2>&1 &

SERVE_PID=$!
echo "vLLM serve gestartet (PID: $SERVE_PID)"
echo "Logs: tail -f $LOGFILE"
echo "Health-Check: curl http://localhost:$PORT/health"
